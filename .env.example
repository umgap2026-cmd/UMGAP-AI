# Copy this file to .env and fill in real values.
# Never commit the real .env — it is gitignored on purpose.

# --- Flask ---
SECRET_KEY=
FLASK_ENV=development
PORT=5000

# --- Database (either DATABASE_URL, or the discrete DB_* vars below) ---
DATABASE_URL=
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_SSLMODE=require
DB_POOL_MIN=1
DB_POOL_MAX=6

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
# Android OAuth client ID used by the Flutter app for "Sign in with Google"
# (only needed if it differs from GOOGLE_CLIENT_ID — required for the mobile
# audience check in routes/mobile/auth.py to accept Android-issued id_tokens)
GOOGLE_ANDROID_CLIENT_ID=

# --- OpenAI (HPP AI review) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- SMTP (email) ---
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Firebase Cloud Messaging (push notifications) ---
# Prefer pasting the whole service-account JSON as a single-line string here
# (FIREBASE_SERVICE_ACCOUNT_JSON) instead of storing the .json file in the repo.
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_SERVICE_ACCOUNT_PATH=

# --- Internal/admin tokens (generate strong random values, e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`) ---
INTERNAL_KEY=
INVITE_CODE=
RESET_OTP_SALT=

# --- WhatsApp bot (VPS terpisah, dipakai untuk OTP, absensi, & notifikasi finance) ---
# Ganti WA_BOT_URL setiap kali bot dipindah ke VPS/IP baru (satu-satunya tempat yang
# perlu diubah — jangan hardcode IP di kode). WA_BOT_KEY harus sama persis dengan
# BOT_KEY yang di-set di environment bot (lihat index.js di VPS).
WA_BOT_URL=
WA_BOT_KEY=

# --- Misc ---
RUN_SCHEMA_ON_REQUEST=false
